{
  "name": "crm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "dev:backend": "node scripts/run-maven.mjs -f apps/api/pom.xml spring-boot:run",
    "dev:backend:stable": "powershell -ExecutionPolicy Bypass -File scripts/start-backend.ps1",
    "db:init": "powershell -ExecutionPolicy Bypass -File scripts/init-db.ps1",
    "validate:env": "node scripts/validate-env.mjs",
    "validate:env:staging": "node scripts/validate-env.mjs staging",
    "validate:env:prod": "node scripts/validate-env.mjs prod",
    "optimize:audit": "node scripts/optimize-audit.mjs",
    "optimize:guard": "node scripts/optimize-audit.mjs --strict",
    "optimize:css:split": "node scripts/split-app-css.mjs",
    "optimize:auto": "npm run optimize:audit && npm run repo:check:layout && npm run lint",
    "repo:check:layout": "node scripts/repo-layout-check.mjs",
    "build": "npm run build --workspace apps/web",
    "build:frontend": "npm run build --workspace apps/web",
    "build:backend": "node scripts/run-maven.mjs -f apps/api/pom.xml -DskipTests package",
    "lint": "npm run lint --workspace apps/web",
    "preview": "npm run preview --workspace apps/web",
    "test:frontend": "npm run test:e2e",
    "test:e2e": "node apps/web/scripts/run-playwright-e2e.mjs",
    "test:e2e:mobile": "node apps/web/scripts/run-playwright-mobile-e2e.mjs",
    "test:e2e:runner": "playwright test --config apps/web/playwright.config.js",
    "perf:smoke": "node scripts/perf-run.mjs smoke",
    "perf:baseline": "node scripts/perf-run.mjs baseline",
    "perf:gate": "npm run perf:baseline && node scripts/perf-gate.mjs",
    "perf:bundle:report": "node scripts/perf-bundle-report.mjs",
    "perf:bundle:baseline:update": "set PERF_BUNDLE_UPDATE_BASELINE=1&& node scripts/perf-bundle-report.mjs",
    "perf:bundle:gate": "node scripts/perf-bundle-gate.mjs",
    "perf:cache:headers": "node scripts/cache-header-check.mjs",
    "perf:sql:explain": "node scripts/perf-sql-explain.mjs",
    "staging:verify": "node scripts/staging-verify.mjs",
    "staging:deploy": "node scripts/staging-deploy.mjs",
    "staging:rollback": "node scripts/staging-rollback.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "staging:release:summary": "node scripts/staging-release-summary.mjs",
    "test:api": "node scripts/run-maven.mjs -f apps/api/pom.xml -DskipTests package && node scripts/api-smoke-test.mjs",
    "test:backend": "node scripts/run-maven.mjs -f apps/api/pom.xml test",
    "test:backend:unit": "npm run test:backend",
    "ci:frontend": "npm run lint && npm run build:frontend && npm run perf:bundle:report && npm run perf:bundle:gate && npm run test:frontend",
    "ci:backend": "npm run build:backend && npm run test:backend:unit",
    "ci:pr": "node scripts/ci-pr.mjs",
    "ci:separated": "node scripts/ci-separated-gate.mjs",
    "test:full": "node scripts/local-e2e.mjs",
    "sre:daily-check": "node scripts/sre-daily-check.mjs",
    "sre:alert-check": "node scripts/sre-alert-check.mjs",
    "drill:backup-restore": "node scripts/drill-backup-restore.mjs",
    "drill:rollback": "node scripts/drill-rollback.mjs",
    "preflight:prod": "node scripts/preflight-prod.mjs",
    "ci:gate": "npm run ci:frontend && npm run ci:backend && npm run test:full && npm run perf:baseline && npm run perf:gate && npm run sre:daily-check && npm run sre:alert-check && npm run security:scan && npm run preflight:prod",
    "release:snapshot": "node scripts/release-snapshot.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
