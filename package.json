{
  "name": "crm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "mvn -f backend/pom.xml spring-boot:run",
    "dev:backend:stable": "powershell -ExecutionPolicy Bypass -File scripts/start-backend.ps1",
    "db:init": "powershell -ExecutionPolicy Bypass -File scripts/init-db.ps1",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "node scripts/run-playwright-e2e.mjs",
    "test:e2e:runner": "playwright test",
    "perf:smoke": "node scripts/perf-run.mjs smoke",
    "perf:baseline": "node scripts/perf-run.mjs baseline",
    "perf:gate": "node scripts/perf-gate.mjs",
    "staging:verify": "node scripts/staging-verify.mjs",
    "staging:deploy": "node scripts/staging-deploy.mjs",
    "staging:rollback": "node scripts/staging-rollback.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "staging:release:summary": "node scripts/staging-release-summary.mjs",
    "test:api": "mvn -f backend/pom.xml -DskipTests package && node scripts/api-smoke-test.mjs",
    "test:backend": "mvn -f backend/pom.xml test",
    "test:full": "node scripts/local-e2e.mjs",
    "sre:daily-check": "node scripts/sre-daily-check.mjs",
    "sre:alert-check": "node scripts/sre-alert-check.mjs",
    "drill:backup-restore": "node scripts/drill-backup-restore.mjs",
    "drill:rollback": "node scripts/drill-rollback.mjs",
    "preflight:prod": "node scripts/preflight-prod.mjs",
    "ci:gate": "npm run lint && npm run build && npm run test:e2e && npm run test:backend && npm run test:full && npm run perf:baseline && npm run perf:gate && npm run sre:daily-check && npm run sre:alert-check && npm run security:scan && npm run preflight:prod",
    "release:snapshot": "node scripts/release-snapshot.mjs"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
