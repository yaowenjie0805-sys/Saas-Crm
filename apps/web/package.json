{
  "name": "crm-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "check:runtime-kernel-imports": "node ../../scripts/runtime-kernel-import-check.mjs",
    "check:pages-entry-exports": "node ../../scripts/pages-entry-export-check.mjs",
    "report:pages-unused-exports": "node ../../scripts/pages-entry-unused-exports-report.mjs",
    "generate:pages-domain-exports": "node ../../scripts/generate-pages-domain-exports.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e:runner": "playwright test --config playwright.config.js",
    "test:e2e:ai-shortcut": "playwright test --config playwright.config.js tests/e2e/topbar-ai-shortcut.spec.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.1",
    "antd": "^5.28.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.18",
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
