# ===========================================
# CRM Backend Local Integration Settings | CRM 后端本地集成配置
# ===========================================
# Copy this file to `.env.backend.local` and fill your own values.
# 复制此文件为 `.env.backend.local` 并填入你自己的值。

# -------------------------------------------
# Webhook Providers | Webhook 提供商配置
# -------------------------------------------
# Enabled webhook providers (comma-separated) | 启用的 Webhook 提供商（逗号分隔）
# Options: WECOM, DINGTALK, FEISHU | 可选值：企业微信, 钉钉, 飞书
INTEGRATION_WEBHOOK_PROVIDERS=WECOM,DINGTALK,FEISHU

# -------------------------------------------
# Feishu App Mode | 飞书 App 模式（推荐）
# -------------------------------------------
# Feishu App ID (from Feishu Open Platform) | 飞书应用 ID（从飞书开放平台获取）
INTEGRATION_FEISHU_APP_ID=

# Feishu App Secret (from Feishu Open Platform) | 飞书应用密钥（从飞书开放平台获取）
INTEGRATION_FEISHU_APP_SECRET=

# Target ID for receiving messages | 接收消息的目标 ID
# - chat_id: 群聊 ID
# - open_id: 用户 open_id
# - user_id: 用户 user_id
# - union_id: 用户 union_id
INTEGRATION_FEISHU_RECEIVE_ID=

# Receive ID type | 接收 ID 类型
# Options: chat_id | open_id | user_id | union_id
INTEGRATION_FEISHU_RECEIVE_ID_TYPE=chat_id

# Feishu API base URL | 飞书 API 基础地址
# Use https://open.feishu.cn for China | 国内使用 https://open.feishu.cn
# Use https://open.larksuite.com for overseas | 海外使用 https://open.larksuite.com
INTEGRATION_FEISHU_BASE_URL=https://open.feishu.cn

# -------------------------------------------
# WeCom Webhook (Optional) | 企业微信 Webhook（可选）
# -------------------------------------------
#INTEGRATION_WECOM_WEBHOOK_URL=
#INTEGRATION_WECOM_SECRET=

# -------------------------------------------
# DingTalk Webhook (Optional) | 钉钉 Webhook（可选）
# -------------------------------------------
#INTEGRATION_DINGTALK_WEBHOOK_URL=
#INTEGRATION_DINGTALK_SECRET=
