# ===========================================
# CRM Backend Local Integration Settings
# ===========================================
# Copy to `.env.backend.local` and fill your own values.

# -------------------------------------------
# Auth Token Secret
# -------------------------------------------
# REQUIRED: must be non-blank and NOT the default value, otherwise login/signing may fail.
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret

# -------------------------------------------
# Seed Tenant (required when APP_SEED_ENABLED=true)
# -------------------------------------------
APP_SEED_ENABLED=true
APP_SEED_TENANT_ID=tenant_default
APP_SEED_DEMO_ENABLED=true
AUTH_BOOTSTRAP_DEFAULT_PASSWORD=admin123

# -------------------------------------------
# Webhook Providers
# -------------------------------------------
INTEGRATION_WEBHOOK_PROVIDERS=WECOM,DINGTALK,FEISHU
# Approval callback tokens for protected workflow actions (comma-separated, higher priority).
# Example: WORKFLOW_APPROVAL_CALLBACK_TOKENS=replace-with-long-random-token-a,replace-with-long-random-token-b
WORKFLOW_APPROVAL_CALLBACK_TOKENS=
# Fallback single approval callback token (used only when TOKENS is empty).
# Example: WORKFLOW_APPROVAL_CALLBACK_TOKEN=replace-with-long-random-token
WORKFLOW_APPROVAL_CALLBACK_TOKEN=
# Optional host suffix allowlist for outbound webhook targets (comma-separated).
# Empty means no suffix restriction.
# Example: INTEGRATION_WEBHOOK_ALLOWED_HOST_SUFFIXES=.example.com,.internal.example
INTEGRATION_WEBHOOK_ALLOWED_HOST_SUFFIXES=

# Feishu App Mode
INTEGRATION_FEISHU_APP_ID=
INTEGRATION_FEISHU_APP_SECRET=
INTEGRATION_FEISHU_RECEIVE_ID=
INTEGRATION_FEISHU_RECEIVE_ID_TYPE=chat_id
INTEGRATION_FEISHU_BASE_URL=https://open.feishu.cn

# WeCom Webhook (Optional)
#INTEGRATION_WECOM_WEBHOOK_URL=
#INTEGRATION_WECOM_SECRET=

# DingTalk Webhook (Optional)
#INTEGRATION_DINGTALK_WEBHOOK_URL=
#INTEGRATION_DINGTALK_SECRET=

# -------------------------------------------
# AI Providers (optional)
# -------------------------------------------
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=https://api.openai.com
AI_OPENAI_MODEL=gpt-4o

AI_ANTHROPIC_API_KEY=
AI_ANTHROPIC_MODEL=claude-3-5-sonnet

# -------------------------------------------
# Tenant Guard
# -------------------------------------------
TENANT_REJECT_MISSING=false
