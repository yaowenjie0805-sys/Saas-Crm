# ===========================================
# CRM .gitignore
# ===========================================

# -------------------------------------------
# Logs | 日志
# -------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------------------------
# Dependencies | 依赖
# -------------------------------------------
node_modules/

# -------------------------------------------
# Build outputs | 构建输出
# -------------------------------------------
dist/
dist-ssr/
apps/web/dist/
apps/api/target/
bin-debug/
bin-release/
[Oo]bj/
[Bb]in/

# -------------------------------------------
# Test results | 测试结果
# -------------------------------------------
apps/web/test-results/
test-results/
verify-*.png

# -------------------------------------------
# Local config | 本地配置
# -------------------------------------------
*.local
.env
.env.local
.env.*.local

# -------------------------------------------
# IDE & Editors | 编辑器
# -------------------------------------------
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs
.idea/
*.iml
.settings/

# Maven
.m2repo/
.mvn/

# macOS
.DS_Store

# Windows
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -------------------------------------------
# Executables | 可执行文件
# -------------------------------------------
*.swf
*.air
*.ipa
*.apk

# -------------------------------------------
# Tool directories | 工具目录
# -------------------------------------------
.codeartsdoer/
.qoder/
.lingma/
.arts/
.claude/

# Backups
backups/

# Evaluation artifacts
evaluation/
