# ===========================================
# CRM Staging Docker Compose Environment
# CRM 预发 Docker Compose 环境配置
# ===========================================
# Copy to staging.env and configure | 复制为 staging.env 并配置

# -------------------------------------------
# Authentication | 认证配置
# -------------------------------------------
# JWT secret (MUST change in production!) | JWT 密钥 (生产环境必须修改!)
AUTH_TOKEN_SECRET=replace-with-strong-secret
# MFA static code for testing | MFA 静态码 (测试用)
SECURITY_MFA_STATIC_CODE=918273
# SSO mode: oidc | disabled | SSO 模式
SECURITY_SSO_MODE=oidc
# Default password for bootstrap | 引导默认密码
AUTH_BOOTSTRAP_DEFAULT_PASSWORD=replace-with-strong-password

# -------------------------------------------
# Database | 数据库配置
# -------------------------------------------
DB_URL=jdbc:mysql://mysql-host:3306/crm_local
DB_USER=crm
DB_PASSWORD=replace-with-db-password

# -------------------------------------------
# Cookie & Security | Cookie 与安全配置
# -------------------------------------------
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Lax
SECURITY_CORS_ALLOWED_ORIGINS=https://staging.crm.example.com

# -------------------------------------------
# Application | 应用配置
# -------------------------------------------
# Disable seed data in staging | 预发环境禁用种子数据
APP_SEED_ENABLED=false
APP_SEED_DEMO_ENABLED=false
# Message queue | 消息队列
LEAD_IMPORT_MQ_PUBLISH_ENABLED=false
