# ===========================================
# CRM Production Environment | CRM 生产环境配置
# ===========================================
# Copy to .env.production and configure for production deployment
# 复制为 .env.production 并为生产部署配置
# IMPORTANT: Never commit actual production secrets! | 重要: 切勿提交实际的生产密钥!

# -------------------------------------------
# Frontend (build-time) | 前端构建配置
# -------------------------------------------
# Relative API path for reverse proxy | 相对 API 路径 (反向代理)
VITE_API_BASE_URL=/api

# -------------------------------------------
# Backend (runtime) | 后端运行配置
# -------------------------------------------
PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Database | 数据库
DB_URL=jdbc:mysql://mysql-host:3306/crm
DB_USER=crm
DB_PASSWORD=replace-with-db-password

# Authentication | 认证
# MUST use strong secret in production! | 生产环境必须使用强密钥!
AUTH_TOKEN_SECRET=replace-with-strong-secret
AUTH_TOKEN_TTL_MS=86400000

# Cookie | Cookie 配置
# Production MUST use HTTPS | 生产环境必须使用 HTTPS
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Lax

# Security | 安全配置
SECURITY_CORS_ALLOWED_ORIGINS=https://crm.example.com

# Seed Data | 种子数据
# Always disable in production | 生产环境始终禁用
APP_SEED_ENABLED=false
APP_SEED_DEMO_ENABLED=false

