# ===========================================
# CRM Environment Configuration | CRM 环境配置
# ===========================================
# Copy this file to .env and update values as needed
# 复制此文件为 .env 并根据需要更新值

# -------------------------------------------
# Frontend | 前端配置
# -------------------------------------------
# API base URL for frontend requests | 前端请求的 API 基础地址
VITE_API_BASE_URL=http://localhost:8080/api

# -------------------------------------------
# Backend | 后端配置 (Spring Boot)
# -------------------------------------------
# Server port | 服务端口
PORT=8080

# Database connection | 数据库连接
# Format: jdbc:mysql://host:port/database?params
DB_URL=jdbc:mysql://127.0.0.1:3306/crm_local?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USER=root
DB_PASSWORD=root

# Authentication | 认证配置
# JWT token secret (CHANGE IN PRODUCTION!) | JWT 密钥 (生产环境必须修改!)
AUTH_TOKEN_SECRET=change-this-secret
# Token TTL in milliseconds (default: 24h) | 令牌有效期 (毫秒, 默认: 24小时)
AUTH_TOKEN_TTL_MS=86400000

# Cookie settings | Cookie 配置
# SameSite: Lax | Strict | None
AUTH_COOKIE_SAME_SITE=Lax
# Secure: true for HTTPS, false for HTTP | 生产环境应为 true
AUTH_COOKIE_SECURE=false

# Security | 安全配置
# Comma-separated allowed origins | 允许的跨域来源 (逗号分隔)
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
