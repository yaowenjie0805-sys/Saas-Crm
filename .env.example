# ===========================================
# CRM Environment Configuration | CRM 环境配置
# ===========================================
# Copy this file to .env and update values as needed
# 复制此文件为 .env 并根据需要更新值

# -------------------------------------------
# Frontend | 前端配置
# -------------------------------------------
# API base URL for frontend requests | 前端请求的 API 基础地址
VITE_API_BASE_URL=http://localhost:8080/api
# Default tenant id for login UI | 登录页默认租户
VITE_DEFAULT_TENANT=tenant_default

# -------------------------------------------
# Backend | 后端配置 (Spring Boot)
# -------------------------------------------
# Server port | 服务端口
PORT=8080

# -------------------------------------------
# Database | 数据库配置
# -------------------------------------------
# MySQL connection URL | MySQL 连接地址
# Format: jdbc:mysql://host:port/database?params
DB_URL=jdbc:mysql://127.0.0.1:3306/crm_local?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
# Database username | 数据库用户名
DB_USER=root
# Database password | 数据库密码
DB_PASSWORD=root

# -------------------------------------------
# Redis | Redis 缓存配置
# -------------------------------------------
# Redis host | Redis 主机地址
REDIS_HOST=127.0.0.1
# Redis port | Redis 端口
REDIS_PORT=6379
# Redis password (leave empty if no auth) | Redis 密码（无密码则留空）
REDIS_PASSWORD=
# Redis database index | Redis 数据库索引
REDIS_DB=0

# -------------------------------------------
# Authentication | 认证配置
# -------------------------------------------
# JWT token secret (CHANGE IN PRODUCTION!) | JWT 密钥（生产环境必须修改！）
AUTH_TOKEN_SECRET=change-this-secret-to-a-strong-random-string
# Token TTL in milliseconds (default: 24h) | 令牌有效期（毫秒，默认: 24小时）
AUTH_TOKEN_TTL_MS=86400000

# -------------------------------------------
# Cookie | Cookie 配置
# -------------------------------------------
# SameSite policy: Lax | Strict | None | SameSite 策略
AUTH_COOKIE_SAME_SITE=Lax
# Secure: true for HTTPS, false for HTTP | 是否启用安全 Cookie（生产环境应为 true）
AUTH_COOKIE_SECURE=false

# -------------------------------------------
# Security | 安全配置
# -------------------------------------------
# Comma-separated allowed CORS origins | 允许的跨域来源（逗号分隔）
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -------------------------------------------
# RabbitMQ | 消息队列配置（可选）
# -------------------------------------------
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# -------------------------------------------
# Feishu Integration | 飞书集成（可选）
# -------------------------------------------
# Feishu App ID | 飞书应用 ID
INTEGRATION_FEISHU_APP_ID=
# Feishu App Secret | 飞书应用密钥
INTEGRATION_FEISHU_APP_SECRET=
# Feishu receive ID (user/chat/open id) | 接收消息的目标 ID
INTEGRATION_FEISHU_RECEIVE_ID=
# Receive ID type: chat_id | open_id | user_id | union_id | 接收 ID 类型
INTEGRATION_FEISHU_RECEIVE_ID_TYPE=chat_id
# Feishu API base URL | 飞书 API 地址
INTEGRATION_FEISHU_BASE_URL=https://open.feishu.cn

# -------------------------------------------
# WeCom/DingTalk Webhook | 企业微信/钉钉 Webhook（可选）
# -------------------------------------------
INTEGRATION_WECOM_WEBHOOK_URL=
INTEGRATION_DINGTALK_WEBHOOK_URL=
INTEGRATION_DINGTALK_SECRET=

# Webhook callback approval tokens (comma-separated, higher priority) | 审批回调多令牌（逗号分隔，优先级更高）
# Example: WORKFLOW_APPROVAL_CALLBACK_TOKENS=replace-with-long-random-token-a,replace-with-long-random-token-b
WORKFLOW_APPROVAL_CALLBACK_TOKENS=
# Webhook callback approval token (fallback when TOKENS is empty) | 审批回调单令牌（仅在 TOKENS 为空时生效）
# Example: WORKFLOW_APPROVAL_CALLBACK_TOKEN=replace-with-long-random-token
WORKFLOW_APPROVAL_CALLBACK_TOKEN=
# Allowed webhook host suffixes (comma-separated) | 允许的 Webhook 主机后缀（逗号分隔）
# 留空表示不限制；示例值仅用于演示
# Example: INTEGRATION_WEBHOOK_ALLOWED_HOST_SUFFIXES=.example.com,.internal.example
INTEGRATION_WEBHOOK_ALLOWED_HOST_SUFFIXES=
