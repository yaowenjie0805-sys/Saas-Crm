# ===========================================
# CRM Staging Environment | CRM 预发环境配置
# ===========================================
# Copy to .env.staging and configure for staging deployment
# 复制为 .env.staging 并为预发部署配置

# -------------------------------------------
# Frontend (build-time) | 前端构建配置
# -------------------------------------------
# Relative API path for reverse proxy | 相对 API 路径 (反向代理)
VITE_API_BASE_URL=/api

# -------------------------------------------
# Backend (runtime) | 后端运行配置
# -------------------------------------------
PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Database | 数据库
DB_URL=jdbc:mysql://mysql-host:3306/crm_local
DB_USER=crm
DB_PASSWORD=replace-with-db-password

# Authentication | 认证
# Use strong secret in staging! | 预发环境使用强密钥!
AUTH_TOKEN_SECRET=replace-with-strong-secret
AUTH_TOKEN_TTL_MS=86400000

# Cookie | Cookie 配置
# Staging should use HTTPS | 预发环境应使用 HTTPS
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Lax

# Security | 安全配置
SECURITY_CORS_ALLOWED_ORIGINS=https://staging.crm.example.com

# Seed Data | 种子数据
# Disable auto-seed in staging | 预发环境禁用自动种子
APP_SEED_ENABLED=false
APP_SEED_DEMO_ENABLED=false

